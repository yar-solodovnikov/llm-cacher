{
  "name": "llm-cacher",
  "version": "1.0.4",
  "description": "Cache LLM responses — exact and semantic matching",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "llm-cacher": "./dist/cli.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nestjs": {
      "types": "./dist/nestjs.d.ts",
      "import": "./dist/nestjs.js",
      "require": "./dist/nestjs.cjs"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js",
      "require": "./dist/express.cjs"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js",
      "require": "./dist/hono.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src tests",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "llm",
    "cache",
    "caching",
    "openai",
    "anthropic",
    "claude",
    "gpt",
    "ai",
    "ai-cache",
    "llm-cache",
    "semantic-cache",
    "semantic-search",
    "embeddings",
    "vector-cache",
    "prompt-caching",
    "response-cache",
    "redis",
    "sqlite",
    "dynamodb",
    "middleware",
    "typescript",
    "nodejs",
    "cost-optimization"
  ],
  "type": "module",
  "license": "MIT",
  "author": "Yaroslav Solodovnikov",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yar-solodovnikov/llm-cacher.git"
  },
  "homepage": "https://yar-solodovnikov.github.io/llm-cacher/",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@aws-sdk/client-dynamodb": "^3.1046.0",
    "@eslint/js": "^10.0.0",
    "@huggingface/transformers": "^4.2.0",
    "@nestjs/common": "^11.1.21",
    "@nestjs/core": "^11.1.21",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.0",
    "better-sqlite3": "^12.10.0",
    "eslint": "^10.0.0",
    "hnswlib-node": "^3.0.0",
    "hono": "^4.12.18",
    "ioredis": "^5.10.1",
    "openai": "^6.37.0",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0",
    "@aws-sdk/client-dynamodb": ">=3.0.0",
    "@huggingface/transformers": ">=3.0.0",
    "@nestjs/common": ">=10.0.0",
    "better-sqlite3": ">=9.0.0",
    "express": ">=4.0.0",
    "hnswlib-node": ">=3.0.0",
    "hono": ">=4.0.0",
    "ioredis": ">=5.0.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "@aws-sdk/client-dynamodb": {
      "optional": true
    },
    "@huggingface/transformers": {
      "optional": true
    },
    "hnswlib-node": {
      "optional": true
    },
    "@nestjs/common": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
