{
  "name": "llm-cache",
  "version": "0.1.0",
  "description": "Cache LLM responses — exact and semantic matching",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests"
  },
  "keywords": [
    "llm",
    "cache",
    "openai",
    "anthropic",
    "ai",
    "semantic-cache",
    "cost-optimization"
  ],
  "type": "module",
  "license": "MIT",
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1046.0",
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^12.10.0",
    "eslint": "^9.0.0",
    "ioredis": "^5.10.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "ioredis": ">=5.0.0",
    "better-sqlite3": ">=9.0.0",
    "@aws-sdk/client-dynamodb": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true },
    "ioredis": { "optional": true },
    "better-sqlite3": { "optional": true },
    "@aws-sdk/client-dynamodb": { "optional": true }
  }
}
